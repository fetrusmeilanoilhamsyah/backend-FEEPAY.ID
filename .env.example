APP_NAME=FEEPAY.ID
APP_ENV=production
APP_KEY=base64:GENERATE_DENGAN_php_artisan_key:generate
APP_DEBUG=false
APP_URL=https://api.feepay.web.id

# ─── Database ────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=feepay_db
DB_USERNAME=feepay_user
DB_PASSWORD=GANTI_PASSWORD_KUAT_MIN_16_KARAKTER

# ─── Digiflazz ───────────────────────────────────────────
DIGIFLAZZ_USERNAME=USERNAME_KAMU
DIGIFLAZZ_API_KEY=API_KEY_DARI_DASHBOARD_DIGIFLAZZ
DIGIFLAZZ_BASE_URL=https://api.digiflazz.com/v1

# ─── Midtrans ────────────────────────────────────────────
MIDTRANS_SERVER_KEY=Mid-server-XXXXXXXXXXXXXXXX
MIDTRANS_CLIENT_KEY=Mid-client-XXXXXXXXXXXXXXXX
MIDTRANS_IS_PRODUCTION=true

# ─── Email (Brevo SMTP) ──────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=USERNAME_BREVO_KAMU
MAIL_PASSWORD=PASSWORD_BREVO_KAMU
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@feepay.web.id"
MAIL_FROM_NAME="FEEPAY.ID"

# ─── Telegram ────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=1234567890:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=987654321

# ─── Support Contacts ────────────────────────────────────
SUPPORT_WHATSAPP=62XXXXXXXXXX
SUPPORT_TELEGRAM=@USERNAME_TELEGRAM
SUPPORT_EMAIL=support@feepay.web.id

# ─── Admin Security ──────────────────────────────────────
FEEPAY_ADMIN_PIN=6_DIGIT_BUKAN_TANGGAL_LAHIR
ADMIN_PATH_PREFIX=STRING_ACAK_PANJANG_MIN_12_KARAKTER
ADMIN_ALLOWED_IPS=IP_VPS_KAMU,IP_RUMAH_KAMU

# ─── Frontend (Vercel) ───────────────────────────────────
FRONTEND_URL=https://NAMA_PROJECT_KAMU.vercel.app
# Jika sudah pakai custom domain:
# FRONTEND_URL=https://feepay.web.id

# ─── Sanctum ─────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=feepay.web.id,api.feepay.web.id,NAMA_PROJECT_KAMU.vercel.app
SANCTUM_TOKEN_EXPIRATION=1440
SESSION_DOMAIN=.feepay.web.id
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true

# ─── Queue & Cache ───────────────────────────────────────
QUEUE_CONNECTION=database
CACHE_DRIVER=file

# ─── Logging ─────────────────────────────────────────────
LOG_CHANNEL=single
LOG_LEVEL=error

# ─── Margin Default Produk ───────────────────────────────
FEEPAY_MARGIN=2000

# ─── Seeder ──────────────────────────────────────────────
ADMIN_EMAIL=emailkamu@domain.com
ADMIN_SEED_PASSWORD=PASSWORD_KUAT_MIN_8_KARAKTER
