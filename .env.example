# ========================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# ========================================

APP_NAME="PPOB Platform"
APP_ENV=production
APP_KEY=base64:GENERATE_WITH_php_artisan_key:generate
APP_DEBUG=false
APP_URL=https://yourdomain.com

# ========================================
# LOGGING
# ========================================
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error
LOG_SLACK_WEBHOOK_URL=

# ========================================
# DATABASE
# ========================================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ppob_production
DB_USERNAME=ppob_user
DB_PASSWORD=STRONG_PASSWORD_HERE

# ========================================
# REDIS (CRITICAL untuk Production)
# ========================================
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=STRONG_REDIS_PASSWORD_HERE
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_QUEUE_DB=2

# ========================================
# MAIL
# ========================================
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@yourdomain.com
MAIL_FROM_NAME="${APP_NAME}"

# ========================================
# SANCTUM
# ========================================
SANCTUM_STATEFUL_DOMAINS=yourdomain.com,www.yourdomain.com
SESSION_DOMAIN=.yourdomain.com

# ========================================
# DIGIFLAZZ API
# ========================================
DIGIFLAZZ_USERNAME=your_production_username
DIGIFLAZZ_API_KEY=your_production_api_key
DIGIFLAZZ_BASE_URL=https://api.digiflazz.com/v1
DIGIFLAZZ_TIMEOUT=30
DIGIFLAZZ_WEBHOOK_SECRET=your_webhook_secret_key

# ========================================
# MIDTRANS PAYMENT GATEWAY
# ========================================
MIDTRANS_SERVER_KEY=your_server_key
MIDTRANS_CLIENT_KEY=your_client_key
MIDTRANS_MERCHANT_ID=your_merchant_id
MIDTRANS_IS_PRODUCTION=true
MIDTRANS_IS_SANITIZED=true
MIDTRANS_IS_3DS=true

# ========================================
# SECURITY
# ========================================
# IP Whitelist untuk admin panel (comma separated)
ADMIN_IP_WHITELIST=103.xxx.xxx.xxx,180.xxx.xxx.xxx

# ========================================
# TELEGRAM NOTIFICATION (Optional)
# ========================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# ========================================
# WHATSAPP API (Optional)
# ========================================
WHATSAPP_API_URL=
WHATSAPP_API_KEY=
WHATSAPP_SENDER_NUMBER=

# ========================================
# FILESYSTEM
# ========================================
FILESYSTEM_DISK=local

# ========================================
# AWS (if using S3)
# ========================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ========================================
# MONITORING & ANALYTICS
# ========================================
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=1.0

# ========================================
# PERFORMANCE
# ========================================
# OPcache akan di-enable di php.ini
OPCACHE_ENABLE=1

# Queue workers (akan di-handle oleh Supervisor)
QUEUE_WORKERS=4
